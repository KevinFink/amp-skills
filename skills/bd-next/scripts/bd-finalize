#!/usr/bin/env bash
set -euo pipefail

# bd-finalize: Commit work in the current repo, close the ticket,
# and push.
#
# Usage: bd-finalize <ticket_id> <commit_message_file> <file>...
#
# The bd close / bd dolt push commands run from the current directory
# (which should be the repo where beads is initialized).

PRODUCT_DIR="$(pwd)"

# Detect the dolt DB directory by finding where .dolt/ lives under .beads/dolt/
if [[ -d "$PRODUCT_DIR/.beads/dolt/prod/.dolt" ]]; then
  PRODUCT_DOLT_DB_DIR="$PRODUCT_DIR/.beads/dolt/prod"
elif [[ -d "$PRODUCT_DIR/.beads/dolt/.dolt" ]]; then
  PRODUCT_DOLT_DB_DIR="$PRODUCT_DIR/.beads/dolt"
else
  echo "Error: could not find dolt database under .beads/dolt/" >&2
  exit 1
fi

sync_product_pull() {
  # Use fetch+reset instead of bd dolt pull to avoid recurring merge
  # conflicts on the metadata table (dolt_auto_push_commit/last rows).
  # See: https://github.com/steveyegge/beads/issues/2466
  (
    cd "$PRODUCT_DOLT_DB_DIR"
    dolt fetch origin >/dev/null 2>&1

    local local_head remote_head
    local_head=$(dolt log --oneline -n 1 2>/dev/null | awk '{print $1}')
    remote_head=$(dolt log --oneline -n 1 origin/main 2>/dev/null | awk '{print $1}')

    if [[ "$local_head" != "$remote_head" ]]; then
      dolt reset --hard origin/main >/dev/null 2>&1
    fi
  )
}

sync_product_push() {
  # Use --force to avoid merge conflicts on metadata table.
  # See: https://github.com/steveyegge/beads/issues/2466
  (
    cd "$PRODUCT_DIR"
    if bd dolt push --force >/dev/null 2>&1; then
      return 0
    fi

    echo "Warning: bd dolt push --force failed; trying direct dolt push fallback..." >&2
    if command -v dolt >/dev/null 2>&1 && [[ -d "$PRODUCT_DOLT_DB_DIR/.dolt" ]]; then
      (cd "$PRODUCT_DOLT_DB_DIR" && dolt push --force origin main >/dev/null)
    else
      echo "Error: could not push Beads changes (bd and dolt fallback both unavailable)." >&2
      return 1
    fi
  )
}

if [[ $# -lt 3 ]]; then
  echo "Usage: bd-finalize <ticket_id> <commit_message_file> <file>..." >&2
  exit 1
fi

ticket_id="$1"
shift
commit_message_file="$1"
shift

if [[ ! -f "$commit_message_file" ]]; then
  echo "Commit message file not found: $commit_message_file" >&2
  exit 1
fi

# --- Safety gate: require explicit confirmation ---
if [[ "${BD_FINALIZE_CONFIRMED:-}" != "yes" ]]; then
  echo ""
  echo "=== bd-finalize: Pre-flight summary ==="
  echo "Ticket:       $ticket_id"
  echo "Commit msg:   $(cat "$commit_message_file")"
  echo "Files to add: $@"
  echo "Actions:      git commit + push, bd close + push"
  echo ""
  echo "To execute, re-run with BD_FINALIZE_CONFIRMED=yes or set that env var."
  echo "If called from Amp, the agent MUST ask the user for approval first."
  exit 0
fi

# --- Working repo: commit the code changes ---
git add "$@"
git commit -F "$commit_message_file"

# Amend if pre-commit hooks modified files
git add -A
if ! git diff --cached --quiet; then
  git commit --amend --no-edit
fi

# Capture commit info for the completion record
COMMIT_HASH=$(git rev-parse --short HEAD)
COMMIT_MSG=$(cat "$commit_message_file" 2>/dev/null || git log -1 --format=%s)
WORKING_REPO=$(basename "$(git rev-parse --show-toplevel)")

rm -f "$commit_message_file"

# Push working repo
git pull --rebase
git push

# --- Add completion record, close ticket, and sync ---
# Sync tracker first so we close on top of the latest state.
sync_product_pull

# Build a structured completion comment
comment="## Completion Record"
comment+=$'\n\n'"**Commit:** \`${COMMIT_HASH}\` in \`${WORKING_REPO}\`"
comment+=$'\n'"**Commit message:** ${COMMIT_MSG}"

# Add Amp thread URLs if provided (space-separated list via env var)
if [[ -n "${AMP_THREAD_URLS:-}" ]]; then
  comment+=$'\n\n'"**Amp thread(s):**"
  for url in $AMP_THREAD_URLS; do
    comment+=$'\n'"- ${url}"
  done
fi

# Add closing notes if provided via env var
if [[ -n "${BD_CLOSE_NOTES:-}" ]]; then
  comment+=$'\n\n'"**Notes:** ${BD_CLOSE_NOTES}"
fi

bd comments add "$ticket_id" "$comment"
bd close "$ticket_id"
git add -A
if ! git diff --cached --quiet; then
  git commit -m "Close $ticket_id"
fi

sync_product_push

git pull --rebase
git push

echo "✓ Finalized $ticket_id — repo pushed."

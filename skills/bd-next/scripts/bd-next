#!/usr/bin/env bash
set -euo pipefail

# bd-next: Fetch the next ready ticket from the current repo and output
# an Amp prompt that starts a new thread for it.
#
# All bd commands run against the current working directory.

PRODUCT_DIR="$(pwd)"

# Detect the dolt DB directory by finding where .dolt/ lives under .beads/dolt/
if [[ -d "$PRODUCT_DIR/.beads/dolt/prod/.dolt" ]]; then
  PRODUCT_DOLT_DB_DIR="$PRODUCT_DIR/.beads/dolt/prod"
elif [[ -d "$PRODUCT_DIR/.beads/dolt/.dolt" ]]; then
  PRODUCT_DOLT_DB_DIR="$PRODUCT_DIR/.beads/dolt"
else
  echo "Error: could not find dolt database under .beads/dolt/" >&2
  exit 1
fi

sync_product_pull() {
  # Use fetch+reset instead of bd dolt pull to avoid recurring merge
  # conflicts on the metadata table (dolt_auto_push_commit/last rows).
  # See: https://github.com/steveyegge/beads/issues/2466
  (
    cd "$PRODUCT_DOLT_DB_DIR"
    dolt fetch origin >/dev/null 2>&1

    local local_head remote_head
    local_head=$(dolt log --oneline -n 1 2>/dev/null | awk '{print $1}')
    remote_head=$(dolt log --oneline -n 1 origin/main 2>/dev/null | awk '{print $1}')

    if [[ "$local_head" != "$remote_head" ]]; then
      dolt reset --hard origin/main >/dev/null 2>&1
    fi
  )
}

sync_product_push() {
  # Use --force to avoid merge conflicts on metadata table.
  # See: https://github.com/steveyegge/beads/issues/2466
  (
    cd "$PRODUCT_DIR"
    if bd dolt push --force >/dev/null 2>&1; then
      return 0
    fi

    echo "Warning: bd dolt push --force failed; trying direct dolt push fallback..." >&2
    if command -v dolt >/dev/null 2>&1 && [[ -d "$PRODUCT_DOLT_DB_DIR/.dolt" ]]; then
      (cd "$PRODUCT_DOLT_DB_DIR" && dolt push --force origin main >/dev/null)
    else
      echo "Error: could not push Beads changes (bd and dolt fallback both unavailable)." >&2
      return 1
    fi
  )
}

override_id="${1:-}"

# Ensure this machine has the latest tracker state before selecting / claiming.
sync_product_pull

if [[ -n "$override_id" && "$override_id" != "_" && "$override_id" != "-" ]]; then
  next_id="$override_id"
else
  next_id=$(bd ready --json | jq -r '.[0].id')
fi

if [[ -z "${next_id:-}" || "$next_id" == "null" ]]; then
  echo "No ready tickets found."
  exit 1
fi

# Mark the ticket as in-progress so concurrent bd-next calls won't pick it
bd update "$next_id" --status in_progress

# Immediately push claim state so other machines see the lock-in quickly.
sync_product_push

# Determine the target repo from the ticket's label
ticket_json=$(bd show "$next_id" --json)
label=$(echo "$ticket_json" | jq -r '.[0].labels[0] // empty')

work_dir="$PRODUCT_DIR"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Build the label context line
if [[ -n "$label" ]]; then
  label_line="- This ticket is labeled \`${label}\`. Code changes happen in ${work_dir}."
else
  label_line="- This ticket has no repo label. Code changes happen in ${work_dir}."
fi

# Build the handoff goal (instructions for the new thread)
handoff_goal="Work on Beads ticket ${next_id}.

- All bd CLI commands (ready, show, close, create, update) MUST be run from ${PRODUCT_DIR}.
${label_line}
- Steps to follow:
  1. Run: bd show ${next_id} --json (from ${PRODUCT_DIR})
  2. Restate and expand the acceptance criteria / definition of done from the ticket.
  3. If it makes sense, break work into sub-tasks, creating new bd tickets (in ${PRODUCT_DIR}) with appropriate dependencies.
  4. Execute the work in ${work_dir}, filing any follow-ups as new bd tickets in ${PRODUCT_DIR}.
  5. STOP before committing. Present a summary of changes, proposed commit message, the ticket being closed (${next_id}), and which repos will be pushed. Ask me for explicit approval before proceeding.
  6. Only after I approve: finalize by setting these env vars and running bd-finalize:
     - AMP_THREAD_URLS: the Amp Thread URL of this thread (from the thread's context)
     - BD_CLOSE_NOTES: a one-or-two sentence summary of what was accomplished
     - BD_FINALIZE_CONFIRMED=yes
     Then run: ${SCRIPT_DIR}/bd-finalize ${next_id} <commit_message_file> <files...>
  - NEVER run git commit, git push, bd close, or bd-finalize without my explicit approval.

Load skills: bd-next"

cat <<PROMPT
Start the next Beads ticket: ${next_id}.

Use the handoff tool to create a new thread with follow: true to switch to it immediately.

Handoff goal:

${handoff_goal}
PROMPT

          "node -e *",
          "npm list*",
          "npm ls*",
          "npm test*",
          "npm view*",
          "npx jest*",
          "pnpm list*",
          "pnpm ls*",
          "pnpm test*",
          "printenv*",
          "pwd",
          "pytest *",
          "python -c *",
          "python -m pytest *",
          "python -m unittest *",
          "python3 -c *",

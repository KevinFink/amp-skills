{
  "amp.permissions": [
    {
      "tool": "Bash",
      "matches": {
        "cmd": [
          "*/bd-finalize *",
          "*/bd-next*",
          "*/photoop-backend/scripts/refresh-admin-ui.sh",
          "*/photoop-backend/scripts/refresh-admin-ui.sh*",

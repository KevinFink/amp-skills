          "*notify-slack/toolbox/notify-slack*",
          "awk *",
          "basename *",
          "bd *",
          "*bd *",
          "cargo metadata*",
          "cargo test*",
          "cat *",
          "curl",
          "curl *",
          "cut *",
          "date*",
          "df *",
          "diff *",
          "dirname *",

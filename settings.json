{
  "amp.experimental.modes": [
    "bombadil"
  ],
  "amp.permissions": [
    {
      "tool": "Bash",
      "matches": {
        "cmd": "bd *"
      },
      "action": "allow"
    },
    {
      "tool": "Bash",
      "matches": {
        "cmd": "*bd *"
      },
      "action": "allow"
    },
    {
      "tool": "Bash",
      "matches": {
        "cmd": "*/bd-next*"
      },
      "action": "allow"
    },
    {
      "tool": "Bash",
      "matches": {
        "cmd": "*/bd-finalize *"
      },
      "action": "allow"
    },
    {
      "tool": "Bash",
      "matches": {
        "cmd": [
          "~/photoop-backend/scripts/refresh-admin-ui.sh*",
          "awk *",
          "basename *",
          "cargo metadata*",
          "cargo test*",
          "cat *",
          "cut *",
          "date*",
          "df *",
          "diff *",
          "dirname *",
          "du *",
          "echo *",
          "env",
          "file *",
          "find *",
          "gh issue*",
          "git add *",
          "git blame*",
          "git branch*",
          "git diff*",
          "git log*",
          "git ls-files*",
          "git pull*",
          "git remote -v*",
          "git rev-parse*",
          "git show*",
          "git stash list*",
          "git status*",
          "git tag*",
          "go list*",
          "go test*",
          "grep *",
          "head *",
          "jq *",
          "ls *",
          "make test*",
          "node --eval *",
          "node -e *",
          "npm list*",
          "npm ls*",
          "npm test*",
          "npm view*",
          "npx jest*",
          "pnpm list*",
          "pnpm ls*",
          "pnpm test*",
          "printenv*",
          "pwd",
          "pytest*",
          "python -c *",
          "python -m pytest*",
          "python -m unittest*",
          "python3 -c *",
          "python3 -m pytest*",
          "python3 -m unittest*",
          "realpath *",
          "rg *",
          "ruff check*",
          "ruff format*",
          "sed -n *",
          "sort *",
          "stat *",
          "tail *",
          "tr *",
          "tree *",
          "uname*",
          "uniq *",
          "uv run pytest*",
          "uv run python -c *",
          "uv run python -m pytest*",
          "uv run python -m unittest*",
          "uv run ruff*",
          "wc *",
          "which *",
          "yq *"
        ]
      },
      "action": "allow"
    },
    {
      "tool": "Bash",
      "action": "ask"
    }
  ],
  "amp.skills.path": "~/amp-skills/skills",
  "amp.cacheDirectory": "~/.cache/amp",
  "amp.dangerouslyAllowAll": false
}
